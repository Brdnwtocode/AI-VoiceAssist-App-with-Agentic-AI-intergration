DEEPGRAM_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Google Cloud Speech-to-Text (long audio transcription + speaker diarization) ──
# Choose ONE method:
#
#   Method A (local dev): point to the JSON key file you downloaded
GOOGLE_APPLICATION_CREDENTIALS=credentials/stt-key.json
#
#   Method B (EC2 / Docker / GitHub Actions): paste the entire JSON as an env var
#     GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
#
# Optional overrides:
GOOGLE_STT_ENABLED=true
GOOGLE_STT_LANGUAGE=vi-VN
